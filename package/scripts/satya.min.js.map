  "no-autoplay-media": {
    "id": "Media-Autoplay",
    "enabled": true,
    "includeHidden": false,
    "metadata": {
      "description": "Any media content such as <audio> and <video> must be not played automatically when the page loads.",
      "help": "To fix this issue, media elements such as <audio> and <video> must not be used with auto play attribute as it hampers the user experience. Benificial for the users who perceive and operate the interface using assistive technologies such as screen readers.",
