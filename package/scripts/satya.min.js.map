  "button-name": {
    "id": "Button-Accessible name",
    "enabled": true,
    "includeHidden": false,
    "metadata": {
      "description": "<button> element must have informative text via innarHTML or any other technics such as aria-label.",
      "help": "To fix this issue, button must have informative text which conveys the purpose of the button to all the users. Benificial for assistive technology users who perceive the interface through text or speech.",
      "helpUrl": "https://dequeuniversity.com/rules/axe/4.4/button-name",
