  "html-has-lang": {
    "id": "HTML-Missing lang",
    "enabled": true,
    "includeHidden": false,
    "metadata": {
      "description": "Every HTML page must have <Lang> attribute defined with correct language code. For e.g. english can be defined as <lang=\"EN\">.",
      "help": "To fix this issue, hTML must have language defined. Benificial for assistive technologies to adopt the settings as per the interface language.",
      "helpUrl": "https://dequeuniversity.com/rules/axe/4.4/html-has-lang",
      "impact": "serious",
      "actId": "",
