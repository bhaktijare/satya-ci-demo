    "id": "LinkTarget-Missing security/ performance",
    "enabled": true,
    "includeHidden": false,
    "metadata": {
      "description": "Link element with target attribute having \"_blank\" value must have rel=\"noopener\" or rel=\"noreferrer\" defined.",
      "help": "To fix this issue, link with target attribute set as \"_blank\" must have rel=\"noopener\" or rel=\"noreferrer\".",
