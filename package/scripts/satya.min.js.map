  "link-name": {
    "id": "Link-Accessible name",
    "enabled": true,
    "includeHidden": false,
    "metadata": {
      "description": "Each hyper link created through <A> must have informative text to understand its desired target. For e.g. \"Contact Us\", \"About Us\", \"Home\".",
      "help": "To fix this issue, hyperlinks must have informative and meaningful text to convey the target page. Benificial for assistive technology users and anyone who percive and operate the interface via text or speech.",
      "helpUrl": "https://dequeuniversity.com/rules/axe/4.4/link-name",
      "impact": "serious",
