  },
  "meta-viewport": {
    "id": "Viewport- disabled scaling/ zooming",
    "enabled": true,
    "includeHidden": false,
    "metadata": {
      "description": "Must viewport attribute does not disable the zooming/ scaling of any HTML page.",
      "help": "To fix this issue, viewport property must not disable zooming/ scaling for any HTML page. This prevents user from magnifying the interface. Benificial for the users who access the interface via via magnification or any other scaling technic.",
      "helpUrl": "https://dequeuniversity.com/rules/axe/4.4/meta-viewport",
      "impact": "critical",
      "actId": "",
      "needsReview": false
    },
