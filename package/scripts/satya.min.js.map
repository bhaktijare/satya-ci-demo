  "heading-order": {
    "id": "Heading-Hierarchical order",
    "enabled": true,
    "includeHidden": false,
    "metadata": {
      "description": "HTML headings on the page must be semantically correct and Hierarchical.",
      "help": "To fix this issue, hTML headings on the page must be used in a hierarchical order. Headings should not skip the level. For e.g. H1 can have H2 next to it for not H3. Benificial for those who operate and understand the interface through assistive technologies.",
      "helpUrl": "https://dequeuniversity.com/rules/axe/4.4/heading-order",
      "impact": "moderate",
      "actId": "",
      "needsReview": false
    },
    "tags": [
