    "enabled": true,
    "includeHidden": false,
    "metadata": {
      "description": "HTML page must have non-empty <title> tag to convey the purpose/ content on the page.",
      "help": "To fix this issue, hTML page must have title defined to support the navigation and convey the page purpose. Benificial for the users who perceive and operate the interface through assistive technologies.",
      "helpUrl": "https://dequeuniversity.com/rules/axe/4.4/document-title",
