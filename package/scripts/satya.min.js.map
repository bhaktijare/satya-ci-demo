  "image-alt": {
    "id": "Image-Missing Alt",
    "enabled": true,
    "includeHidden": false,
    "metadata": {
      "description": "<IMG> element must have alt attribute defined with meaningful text for an informative image or role attribute as \"None\" or \"Presentation\" for decorative image.",
      "help": "To fix this issue, informative images must have alternative text which enables user to understand the meaning of an image. Beneficial for screen reader users or anyone who perceive the content without vision.",
      "helpUrl": "https://dequeuniversity.com/rules/axe/4.4/image-alt",
      "impact": "critical",
      "actId": "",
      "needsReview": false
